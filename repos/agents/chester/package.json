{
  "name": "@agent/chester",
  "version": "1.0.0",
  "description": "Search orchestrator agent — queries Spotify and streams results to Emily",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "dev": "mastra dev",
    "build": "mastra build && tsc -p tsconfig.build.json",
