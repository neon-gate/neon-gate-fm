{
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@emily": ["./src/emily/emily.agent.ts"],
      "@transform": ["./src/emily/transform/index.ts"],
      "@tools": ["./src/emily/tools/index.ts"],
      "@resilience": ["./src/emily/resilience/index.ts"],
      "@events": ["./src/emily/events/index.ts"],
      "@mcp": ["./src/emily/mcp/index.ts"],
      "@emily-types/*": ["./src/emily/types/*"],
      "@mastra/*": ["./src/mastra/*"]
    }
  }
}
