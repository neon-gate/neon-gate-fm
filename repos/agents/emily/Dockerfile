FROM node:20-alpine

WORKDIR /workspace
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

RUN corepack enable

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY repos ./repos

RUN pnpm install --frozen-lockfile
RUN pnpm turbo run build --filter=@agent/emily

WORKDIR /workspace/repos/agents/emily
COPY repos/agents/emily/.env .env
EXPOSE 4111

CMD ["pnpm", "start"]
