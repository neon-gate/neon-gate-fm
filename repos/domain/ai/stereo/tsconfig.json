{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2022",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@stereo/application/*": ["./src/modules/stereo/application/*"],
      "@stereo/domain/*": ["./src/modules/stereo/domain/*"],
      "@stereo/infra/*": ["./src/modules/stereo/infra/*"],
      "@stereo/interface/*": ["./src/modules/stereo/interface/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
