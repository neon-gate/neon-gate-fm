{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2022",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@petrified/application/*": ["./src/modules/petrified/application/*"],
      "@petrified/domain/*": ["./src/modules/petrified/domain/*"],
      "@petrified/infra/*": ["./src/modules/petrified/infra/*"],
      "@petrified/interface/*": ["./src/modules/petrified/interface/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
